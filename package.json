{
  "name": "@linatang/playwright-browser-manager-mcp",
  "version": "0.2.1",
  "description": "Playwright MCP browser manager for multi-session automation with profile isolation and auto-healing recovery",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "playwright-browser-manager-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "playwright",
    "browser-automation",
    "browser-manager",
    "multi-session",
    "agent-tools",
    "agentic",
    "profile-isolation",
    "auto-healing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lumoslnt/playwright-browser-manager-mcp.git"
  },
  "homepage": "https://github.com/lumoslnt/playwright-browser-manager-mcp#readme",
  "bugs": {
    "url": "https://github.com/lumoslnt/playwright-browser-manager-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "readme:npm": "node scripts/sync-readme.mjs npm",
    "readme:github": "node scripts/sync-readme.mjs github",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run readme:npm && npm run build",
    "postpublish": "npm run readme:github",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "execa": "^9.5.2",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.0"
  }
}
